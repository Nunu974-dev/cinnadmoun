# ===========================
# Configuration Cache pour Cinnad'moun
# ===========================

# Activer le moteur de réécriture
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# ===========================
# Contrôle du Cache des fichiers statiques
# ===========================

<IfModule mod_headers.c>
    # JavaScript et CSS : Cache court (1 heure)
    # Permet les mises à jour rapides tout en gardant de la performance
    <FilesMatch "\.(js|css)$">
        Header set Cache-Control "max-age=3600, must-revalidate"
        Header set Pragma "no-cache"
        Header append Vary "Accept-Encoding"
    </FilesMatch>
    
    # Images : Cache long (7 jours) - elles changent rarement
    <FilesMatch "\.(jpg|jpeg|png|gif|webp|svg|ico)$">
        Header set Cache-Control "max-age=604800, public"
    </FilesMatch>
    
    # HTML : Pas de cache - toujours frais
    <FilesMatch "\.(html|htm)$">
        Header set Cache-Control "no-cache, no-store, must-revalidate"
        Header set Pragma "no-cache"
        Header set Expires "0"
    </FilesMatch>
    
    # Fonts : Cache long (30 jours)
    <FilesMatch "\.(woff|woff2|ttf|eot)$">
        Header set Cache-Control "max-age=2592000, public"
    </FilesMatch>
</IfModule>

# ===========================
# Compression GZIP pour performances
# ===========================

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# ===========================
# Sécurité
# ===========================

# Empêcher l'accès aux fichiers sensibles
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Protection contre les injections
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# ===========================
# Redirection HTTPS (si vous avez un certificat SSL)
# ===========================

# Décommentez ces lignes si vous voulez forcer HTTPS :
# <IfModule mod_rewrite.c>
#     RewriteCond %{HTTPS} off
#     RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
# </IfModule>
